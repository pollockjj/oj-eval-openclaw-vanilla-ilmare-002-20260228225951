#pragma once
#ifndef SJTU_BIGINTEGER
#define SJTU_BIGINTEGER

#include <complex>
#include <cstdio>
#include <cstring>
#include <iostream>
#include <vector>
#include <string>
#include <algorithm>

namespace sjtu {

class int2048 {
private:
    static const long long BASE = 100000000LL; // 10^8
    static const int BASEDIGITS = 8;
    std::vector<long long> d; // little-endian, d[0] is least significant
    bool neg;                  // true if negative

    void trim();
    bool isZero() const;
    // Compare absolute values: -1 if |this| < |o|, 0 if equal, 1 if |this| > |o|
    int cmpAbs(const int2048 &o) const;
    // Add absolute values (both treated as positive), store in this
    void addAbs(const int2048 &o);
    // Subtract absolute values |this| -= |o|, assuming |this| >= |o|
    void subAbs(const int2048 &o);

    // NTT-based multiplication helper
    static std::vector<long long> multiply_vec(const std::vector<long long> &a, const std::vector<long long> &b);

    // Division helpers
    // Divide |this| by |o|, return (quotient, remainder) both non-negative
    static void divmod(const int2048 &a, const int2048 &b, int2048 &q, int2048 &r);

public:
    int2048();
    int2048(long long);
    int2048(const std::string &);
    int2048(const int2048 &);

    void read(const std::string &);
    void print();

    int2048 &add(const int2048 &);
    friend int2048 add(int2048, const int2048 &);

    int2048 &minus(const int2048 &);
    friend int2048 minus(int2048, const int2048 &);

    int2048 operator+() const;
    int2048 operator-() const;

    int2048 &operator=(const int2048 &);

    int2048 &operator+=(const int2048 &);
    friend int2048 operator+(int2048, const int2048 &);

    int2048 &operator-=(const int2048 &);
    friend int2048 operator-(int2048, const int2048 &);

    int2048 &operator*=(const int2048 &);
    friend int2048 operator*(int2048, const int2048 &);

    int2048 &operator/=(const int2048 &);
    friend int2048 operator/(int2048, const int2048 &);

    int2048 &operator%=(const int2048 &);
    friend int2048 operator%(int2048, const int2048 &);

    friend std::istream &operator>>(std::istream &, int2048 &);
    friend std::ostream &operator<<(std::ostream &, const int2048 &);

    friend bool operator==(const int2048 &, const int2048 &);
    friend bool operator!=(const int2048 &, const int2048 &);
    friend bool operator<(const int2048 &, const int2048 &);
    friend bool operator>(const int2048 &, const int2048 &);
    friend bool operator<=(const int2048 &, const int2048 &);
    friend bool operator>=(const int2048 &, const int2048 &);
};

} // namespace sjtu

#endif

#include <cassert>

namespace sjtu {

// ======================== Helpers ========================

void int2048::trim() {
    while (d.size() > 1 && d.back() == 0) d.pop_back();
    if (d.size() == 1 && d[0] == 0) neg = false;
}

bool int2048::isZero() const {
    return d.size() == 1 && d[0] == 0;
}

int int2048::cmpAbs(const int2048 &o) const {
    if (d.size() != o.d.size()) return d.size() < o.d.size() ? -1 : 1;
    for (int i = (int)d.size() - 1; i >= 0; i--) {
        if (d[i] != o.d[i]) return d[i] < o.d[i] ? -1 : 1;
    }
    return 0;
}

void int2048::addAbs(const int2048 &o) {
    long long carry = 0;
    size_t n = std::max(d.size(), o.d.size());
    d.resize(n);
    for (size_t i = 0; i < n; i++) {
        long long sum = d[i] + (i < o.d.size() ? o.d[i] : 0) + carry;
        carry = sum / BASE;
        d[i] = sum % BASE;
    }
    if (carry) d.push_back(carry);
}

void int2048::subAbs(const int2048 &o) {
    // |this| >= |o|
    long long borrow = 0;
    for (size_t i = 0; i < d.size(); i++) {
        long long diff = d[i] - (i < o.d.size() ? o.d[i] : 0) - borrow;
        if (diff < 0) {
            diff += BASE;
            borrow = 1;
        } else {
            borrow = 0;
        }
        d[i] = diff;
    }
    trim();
}

// ======================== NTT ========================

static const long long MOD1 = 998244353;
static const long long G1 = 3;

static long long power(long long a, long long b, long long mod) {
    long long res = 1;
    a %= mod;
    while (b > 0) {
        if (b & 1) res = (__int128)res * a % mod;
        a = (__int128)a * a % mod;
        b >>= 1;
    }
    return res;
}

static void ntt(std::vector<long long> &a, bool inv, long long mod, long long g) {
    int n = a.size();
    for (int i = 1, j = 0; i < n; i++) {
        int bit = n >> 1;
        for (; j & bit; bit >>= 1) j ^= bit;
        j ^= bit;
        if (i < j) std::swap(a[i], a[j]);
    }
    for (int len = 2; len <= n; len <<= 1) {
        long long w = inv ? power(g, mod - 1 - (mod - 1) / len, mod) : power(g, (mod - 1) / len, mod);
        for (int i = 0; i < n; i += len) {
            long long wn = 1;
            for (int j = 0; j < len / 2; j++) {
                long long u = a[i + j];
                long long v = (__int128)a[i + j + len / 2] * wn % mod;
                a[i + j] = (u + v) % mod;
                a[i + j + len / 2] = (u - v + mod) % mod;
                wn = (__int128)wn * w % mod;
            }
        }
    }
    if (inv) {
        long long inv_n = power(n, mod - 2, mod);
        for (auto &x : a) x = (__int128)x * inv_n % mod;
    }
}

// Multiply two vectors of non-negative integers using NTT
// Result may have carries > BASE; caller normalizes
std::vector<long long> int2048::multiply_vec(const std::vector<long long> &a, const std::vector<long long> &b) {
    if (a.empty() || b.empty()) return {0};
    
    int result_size = a.size() + b.size();
    int n = 1;
    while (n < result_size) n <<= 1;
    
    // For BASE=10^8, max digit is ~10^8. Product of two digits * n could overflow.
    // We use two NTT primes and CRT.
    // Max value per position: BASE^2 * min(a.size, b.size) ~ 10^16 * 10^6 = 10^22
    // Single mod won't work. Use two mods.
    
    static const long long MOD2 = 985661441; // 2^23 * 117 + 1, primitive root 3
    
    // We'll split each digit into two halves to keep values manageable
    // Actually for BASE=10^8, each digit < 10^8
    // Convolution value at each position <= 10^8 * 10^8 * n <= 10^16 * 2^20 ~ 10^22
    // MOD1 * MOD2 ~ 10^18 which is too small.
    // 
    // Solution: use BASE=10^4 for NTT, then recombine.
    // Split each base-10^8 digit into two base-10^4 digits.
    
    static const long long NTT_BASE = 10000;
    
    // Split a and b into base-10^4
    std::vector<long long> fa(n, 0), fb(n, 0);
    for (size_t i = 0; i < a.size(); i++) {
        fa[2 * i] = a[i] % NTT_BASE;
        fa[2 * i + 1] = a[i] / NTT_BASE;
    }
    for (size_t i = 0; i < b.size(); i++) {
        fb[2 * i] = b[i] % NTT_BASE;
        fb[2 * i + 1] = b[i] / NTT_BASE;
    }
    
    // Now max convolution value = 10^4 * 10^4 * n = 10^8 * n
    // For n up to 2^21 ~ 2*10^6, max ~ 2*10^14, fits in long long and < MOD1
    // Actually wait, n could be up to 2 * 500000 / 4 * 2 = ... let me recalculate
    // For 500000 decimal digits, that's 500000/8 ~ 62500 base-10^8 cells
    // Split into base-10^4: 125000 cells. n rounded up to power of 2 ~ 2^18 = 262144
    // Result size ~ 250000. n ~ 2^19 = 524288
    // Max conv value = 10^4 * 10^4 * 524288 = 10^8 * 5*10^5 ~ 5*10^13 < 10^18 < MOD1
    // Single NTT mod suffices!
    
    // But wait, we need result_size for the split arrays
    int split_result = 2 * a.size() + 2 * b.size();
    n = 1;
    while (n < split_result) n <<= 1;
    fa.resize(n, 0);
    fb.resize(n, 0);
    
    ntt(fa, false, MOD1, G1);
    ntt(fb, false, MOD1, G1);
    for (int i = 0; i < n; i++) fa[i] = (__int128)fa[i] * fb[i] % MOD1;
    ntt(fa, true, MOD1, G1);
    
    // Now fa contains convolution in base-10^4
    // Convert back to base-10^8
    // fa[2*i] and fa[2*i+1] contribute to result[i] and neighboring cells
    // Actually no - fa is the raw convolution of the split arrays. We need to 
    // recombine: result in base-10^4, then convert to base-10^8.
    
    // Normalize carries in base-10^4 first
    std::vector<long long> res_split(n);
    long long carry = 0;
    for (int i = 0; i < n; i++) {
        long long val = fa[i] + carry;
        res_split[i] = val % NTT_BASE;
        carry = val / NTT_BASE;
    }
    
    // Convert base-10^4 to base-10^8
    int res_len = (n + 1) / 2 + 1;
    std::vector<long long> result(res_len, 0);
    for (int i = 0; i < n; i++) {
        int idx = i / 2;
        if (i % 2 == 0) result[idx] += res_split[i];
        else result[idx] += res_split[i] * NTT_BASE;
    }
    // Handle carry from conversion
    carry = 0;
    for (int i = 0; i < (int)result.size(); i++) {
        result[i] += carry;
        carry = result[i] / BASE;
        result[i] %= BASE;
    }
    while (carry) {
        result.push_back(carry % BASE);
        carry /= BASE;
    }
    // Trim trailing zeros
    while (result.size() > 1 && result.back() == 0) result.pop_back();
    
    return result;
}

// ======================== Constructors ========================

int2048::int2048() : d(1, 0), neg(false) {}

int2048::int2048(long long v) : neg(false) {
    if (v < 0) {
        neg = true;
        // Handle LLONG_MIN carefully
        unsigned long long uv = (unsigned long long)(-(v + 1)) + 1ULL;
        if (uv == 0) { d.push_back(0); }
        else {
            while (uv > 0) {
                d.push_back((long long)(uv % BASE));
                uv /= BASE;
            }
        }
    } else if (v == 0) {
        d.push_back(0);
    } else {
        while (v > 0) {
            d.push_back(v % BASE);
            v /= BASE;
        }
    }
    if (d.empty()) d.push_back(0);
}

int2048::int2048(const std::string &s) : neg(false) {
    read(s);
}

int2048::int2048(const int2048 &o) : d(o.d), neg(o.neg) {}

// ======================== read / print ========================

void int2048::read(const std::string &s) {
    d.clear();
    neg = false;
    int start = 0;
    if (!s.empty() && s[0] == '-') {
        neg = true;
        start = 1;
    } else if (!s.empty() && s[0] == '+') {
        start = 1;
    }
    // Skip leading zeros
    while (start < (int)s.size() - 1 && s[start] == '0') start++;
    
    // Parse from right to left in chunks of BASEDIGITS
    for (int i = (int)s.size() - 1; i >= start; i -= BASEDIGITS) {
        long long val = 0;
        int beg = std::max(start, i - BASEDIGITS + 1);
        for (int j = beg; j <= i; j++) {
            val = val * 10 + (s[j] - '0');
        }
        d.push_back(val);
    }
    if (d.empty()) d.push_back(0);
    trim();
}

void int2048::print() {
    if (neg) putchar('-');
    printf("%lld", d.back());
    for (int i = (int)d.size() - 2; i >= 0; i--) {
        printf("%08lld", d[i]);
    }
}

// ======================== add / minus (Integer 1) ========================

int2048 &int2048::add(const int2048 &o) {
    if (neg == o.neg) {
        addAbs(o);
    } else {
        int c = cmpAbs(o);
        if (c >= 0) {
            subAbs(o);
        } else {
            int2048 tmp(o);
            tmp.subAbs(*this);
            *this = tmp;
        }
    }
    return *this;
}

int2048 add(int2048 a, const int2048 &b) {
    return a.add(b);
}

int2048 &int2048::minus(const int2048 &o) {
    // this -= o  is same as  this += (-o)
    int2048 tmp(o);
    tmp.neg = !tmp.neg;
    if (tmp.isZero()) tmp.neg = false;
    return this->add(tmp);
}

int2048 minus(int2048 a, const int2048 &b) {
    return a.minus(b);
}

// ======================== Unary ========================

int2048 int2048::operator+() const {
    return *this;
}

int2048 int2048::operator-() const {
    int2048 res(*this);
    if (!res.isZero()) res.neg = !res.neg;
    return res;
}

// ======================== Assignment ========================

int2048 &int2048::operator=(const int2048 &o) {
    if (this != &o) {
        d = o.d;
        neg = o.neg;
    }
    return *this;
}

// ======================== Arithmetic operators ========================

int2048 &int2048::operator+=(const int2048 &o) {
    return this->add(o);
}

int2048 operator+(int2048 a, const int2048 &b) {
    return a += b;
}

int2048 &int2048::operator-=(const int2048 &o) {
    return this->minus(o);
}

int2048 operator-(int2048 a, const int2048 &b) {
    return a -= b;
}

int2048 &int2048::operator*=(const int2048 &o) {
    if (isZero() || o.isZero()) {
        d.assign(1, 0);
        neg = false;
        return *this;
    }
    bool result_neg = neg != o.neg;
    
    // Choose schoolbook vs NTT based on size
    size_t total = d.size() + o.d.size();
    if (d.size() <= 64 || o.d.size() <= 64) {
        // Schoolbook multiplication
        std::vector<long long> res(total, 0);
        for (size_t i = 0; i < d.size(); i++) {
            long long carry = 0;
            for (size_t j = 0; j < o.d.size(); j++) {
                __int128 cur = (__int128)d[i] * o.d[j] + res[i + j] + carry;
                res[i + j] = (long long)(cur % BASE);
                carry = (long long)(cur / BASE);
            }
            if (carry) res[i + o.d.size()] += carry;
        }
        d = res;
    } else {
        d = multiply_vec(d, o.d);
    }
    neg = result_neg;
    trim();
    return *this;
}

int2048 operator*(int2048 a, const int2048 &b) {
    return a *= b;
}

// ======================== Division ========================

void int2048::divmod(const int2048 &a, const int2048 &b, int2048 &q, int2048 &r) {
    // Divide |a| by |b|, return quotient and remainder (both >= 0)
    // Assumes b != 0
    
    int c = a.cmpAbs(b);
    if (c < 0) {
        q = int2048(0LL);
        r = a;
        r.neg = false;
        return;
    }
    if (c == 0) {
        q = int2048(1LL);
        r = int2048(0LL);
        return;
    }
    
    // If divisor is small (fits in one cell), do simple long division
    if (b.d.size() == 1) {
        long long divisor = b.d[0];
        q.d.resize(a.d.size());
        q.neg = false;
        long long rem = 0;
        for (int i = (int)a.d.size() - 1; i >= 0; i--) {
            __int128 cur = (__int128)rem * BASE + a.d[i];
            q.d[i] = (long long)(cur / divisor);
            rem = (long long)(cur % divisor);
        }
        q.trim();
        r = int2048(0LL);
        r.d = {rem};
        r.trim();
        return;
    }
    
    // For larger divisors, use schoolbook long division in base BASE
    // We divide chunk by chunk from the most significant
    
    // Make copies of absolute values
    int2048 aa(a);
    aa.neg = false;
    int2048 bb(b);
    bb.neg = false;
    
    int n = (int)aa.d.size();
    int m = (int)bb.d.size();
    
    q.d.resize(n - m + 1, 0);
    q.neg = false;
    
    // Long division: process from most significant position
    // We'll use a running remainder
    int2048 rem;
    rem.d.clear();
    rem.neg = false;
    
    for (int i = n - 1; i >= 0; i--) {
        // Shift remainder left by one cell and add next digit
        rem.d.insert(rem.d.begin(), aa.d[i]);
        rem.trim();
        
        if (rem.cmpAbs(bb) < 0) {
            q.d[i] = 0;
            continue;
        }
        
        // Binary search for the quotient digit
        long long lo = 1, hi = BASE - 1;
        
        // Estimate quotient digit
        // rem / bb approximately
        if (rem.d.size() == bb.d.size()) {
            hi = rem.d.back() / bb.d.back();
            lo = std::max(1LL, hi - 2);
            hi = std::min(BASE - 1, hi + 2);
        } else if (rem.d.size() == bb.d.size() + 1) {
            __int128 top = (__int128)rem.d.back() * BASE + rem.d[rem.d.size() - 2];
            long long est = (long long)(top / bb.d.back());
            lo = std::max(1LL, est - 2);
            hi = std::min(BASE - 1, est + 2);
        }
        
        // Binary search
        while (lo < hi) {
            long long mid = lo + (hi - lo + 1) / 2;
            int2048 tmp(bb);
            // Multiply bb by mid
            long long carry = 0;
            tmp.d.resize(bb.d.size() + 1, 0);
            for (size_t j = 0; j < bb.d.size(); j++) {
                __int128 val = (__int128)bb.d[j] * mid + carry;
                tmp.d[j] = (long long)(val % BASE);
                carry = (long long)(val / BASE);
            }
            tmp.d[bb.d.size()] = carry;
            tmp.trim();
            
            if (tmp.cmpAbs(rem) <= 0) {
                lo = mid;
            } else {
                hi = mid - 1;
            }
        }
        
        q.d[i] = lo;
        
        // Compute rem -= bb * lo
        int2048 product;
        product.d.resize(bb.d.size() + 1, 0);
        product.neg = false;
        long long carry = 0;
        for (size_t j = 0; j < bb.d.size(); j++) {
            __int128 val = (__int128)bb.d[j] * lo + carry;
            product.d[j] = (long long)(val % BASE);
            carry = (long long)(val / BASE);
        }
        product.d[bb.d.size()] = carry;
        product.trim();
        
        rem.subAbs(product);
    }
    
    q.trim();
    r = rem;
    r.neg = false;
    r.trim();
}

int2048 &int2048::operator/=(const int2048 &o) {
    bool result_neg = neg != o.neg;
    int2048 q, r;
    divmod(*this, o, q, r);
    
    // Floor division: if remainder != 0 and signs differ, subtract 1 from quotient
    if (!r.isZero() && result_neg) {
        q.add(int2048(1LL));
    }
    
    *this = q;
    neg = result_neg;
    if (isZero()) neg = false;
    return *this;
}

int2048 operator/(int2048 a, const int2048 &b) {
    return a /= b;
}

int2048 &int2048::operator%=(const int2048 &o) {
    // x % y = x - (x / y) * y
    int2048 q = *this / o;
    *this -= q * o;
    return *this;
}

int2048 operator%(int2048 a, const int2048 &b) {
    return a %= b;
}

// ======================== Stream operators ========================

std::istream &operator>>(std::istream &is, int2048 &v) {
    std::string s;
    is >> s;
    v.read(s);
    return is;
}

std::ostream &operator<<(std::ostream &os, const int2048 &v) {
    if (v.neg) os << '-';
    os << v.d.back();
    char buf[16];
    for (int i = (int)v.d.size() - 2; i >= 0; i--) {
        snprintf(buf, sizeof(buf), "%08lld", v.d[i]);
        os << buf;
    }
    return os;
}

// ======================== Comparison operators ========================

bool operator==(const int2048 &a, const int2048 &b) {
    return a.neg == b.neg && a.d == b.d;
}

bool operator!=(const int2048 &a, const int2048 &b) {
    return !(a == b);
}

bool operator<(const int2048 &a, const int2048 &b) {
    if (a.neg != b.neg) return a.neg;
    if (a.neg) return a.cmpAbs(b) > 0;
    return a.cmpAbs(b) < 0;
}

bool operator>(const int2048 &a, const int2048 &b) {
    return b < a;
}

bool operator<=(const int2048 &a, const int2048 &b) {
    return !(b < a);
}

bool operator>=(const int2048 &a, const int2048 &b) {
    return !(a < b);
}

} // namespace sjtu
